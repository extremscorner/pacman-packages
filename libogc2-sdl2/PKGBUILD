# Maintainer: Extrems <extrems@extremscorner.org>

_pkgname=SDL2
pkgname="libogc2-${_pkgname,,}"
pkgver=2.28.5
pkgrel=24
pkgdesc='A library for portable low-level access to a video framebuffer, audio output, mouse, and keyboard. (Version 2)'
arch=('any')
url='https://www.libsdl.org/'
license=('Zlib')
groups=('gamecube-portlibs' 'gamecube-sdl2-libs' 'wii-portlibs' 'wii-sdl2-libs')
depends=('devkitPPC' 'libogc2' 'libogc2-libfat')
makedepends=('catnip' 'cmake' 'git' 'libogc2-cmake' 'libogc2-opengx')
optdepends=('libogc2-opengx: OpenGL support')
provides=({gamecube,wii}-${_pkgname,,})
options=(!strip libtool staticlibs !buildflags)
source=('git+https://github.com/extremscorner/SDL.git#commit=b46a453f19f084c06b40c6abab5e64ca43cec3df')
sha256sums=('36bf4d8cba33912f75f086e5abd9d3b3b1bcac4894cc0694c255db28cd088f04')

build() {
	cd "${srcdir}/${_pkgname%?}"
	catnip build -DSDL_SYSTEM_ICONV=OFF
}

package() {
	cd "${srcdir}/${_pkgname%?}"
	DESTDIR="${pkgdir}" catnip install
}
