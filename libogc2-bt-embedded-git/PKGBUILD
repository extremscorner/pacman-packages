# Maintainer: Extrems <extrems@extremscorner.org>

_pkgname=bt-embedded
pkgname=(libogc2-${_pkgname}{,-obex}-git)
pkgver=r283.fe0a03a
pkgrel=2
pkgdesc='Bluetooth classic library for embedded devices.'
arch=('any')
url='https://github.com/extremscorner/bt-embedded'
license=('BSD-3-Clause')
groups=('wii-portlibs')
depends=('devkitPPC' 'libogc2')
makedepends=('cmake' 'git' 'libogc2-dkp-toolchain-vars' 'libogc2-openobex')
provides=("libogc2-${_pkgname}")
conflicts=("libogc2-${_pkgname}")
options=(!strip libtool staticlibs)
source=("git+${url}.git")
sha256sums=('SKIP')

pkgver() {
	cd "${srcdir}/${_pkgname}"
	printf "r%s.%s" "$(git rev-list --count HEAD)" "$(git rev-parse --short=7 HEAD)"
}

build() {
	cd "${srcdir}/${_pkgname}"
	source "${DEVKITPRO}/libogc2/wiivars.sh"
	powerpc-eabi-cmake -B build -DWITH_OPENOBEX=OFF
	powerpc-eabi-cmake -B build-obex
	cmake --build build
	cmake --build build-obex
}

package_libogc2-bt-embedded-git() {
	cd "${srcdir}/${_pkgname}"
	source "${DEVKITPRO}/libogc2/wiivars.sh"
	DESTDIR="${pkgdir}" cmake --install build
	install -Dm 644 LICENSE.txt -t "${pkgdir}${PORTLIBS_PREFIX}/share/licenses/${_pkgname}"
}

package_libogc2-bt-embedded-obex-git() {
	pkgdesc+=' (with OBEX support)'
	license=('LGPL-2.1-or-later')
	groups=()
	depends+=('libogc2-openobex')
	provides+=("libogc2-${_pkgname}-git")
	conflicts+=("libogc2-${_pkgname}-git")

	cd "${srcdir}/${_pkgname}"
	source "${DEVKITPRO}/libogc2/wiivars.sh"
	DESTDIR="${pkgdir}" cmake --install build-obex
	install -Dm 644 LICENSE.txt -t "${pkgdir}${PORTLIBS_PREFIX}/share/licenses/${_pkgname}"
}
