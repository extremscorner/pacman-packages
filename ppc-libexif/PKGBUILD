# Maintainer: Extrems <extrems@extremscorner.org>

_pkgname=libexif
pkgname="ppc-${_pkgname}"
pkgver=0.6.26
pkgrel=1
pkgdesc='A library for parsing, editing, and saving EXIF data.'
arch=('any')
url='https://github.com/libexif/libexif'
license=('LGPL-2.0-or-later')
groups=('ppc-portlibs')
depends=('devkitPPC')
makedepends=('libogc2-dkp-toolchain-vars')
options=(!strip libtool staticlibs)
source=("${_pkgname}-${pkgver}.tar.gz::${url}/archive/refs/tags/v${pkgver}.tar.gz")
sha256sums=('32e591455339504b7d02f3e9b0a48f16f5455462a9059a7f47639980e82e4bc1')

prepare() {
	cd "${srcdir}/${_pkgname}-${pkgver}"
	autoreconf -i
}

build() {
	cd "${srcdir}/${_pkgname}-${pkgver}"
	source "${DEVKITPRO}/libogc2/ppcvars.sh"
	./configure --prefix="${PORTLIBS_PREFIX}" --host=powerpc-eabi --disable-docs
	make
}

package() {
	cd "${srcdir}/${_pkgname}-${pkgver}"
	source "${DEVKITPRO}/libogc2/ppcvars.sh"
	DESTDIR="${pkgdir}" make install
	rm -r "${pkgdir}${PORTLIBS_PREFIX}/share"
	install -Dm 644 COPYING -t "${pkgdir}${PORTLIBS_PREFIX}/licenses/${pkgname}"
}
