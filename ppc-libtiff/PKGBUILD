# Maintainer: Extrems <extrems@extremscorner.org>

_pkgname=tiff
pkgname="ppc-lib${_pkgname}"
pkgver=4.7.2
pkgrel=1
pkgdesc='Library for manipulation of TIFF images.'
arch=('any')
url='http://www.simplesystems.org/libtiff/'
license=('libtiff')
groups=('ppc-portlibs')
depends=('devkitPPC' 'ppc-libdeflate' 'ppc-libjpeg-turbo' 'ppc-libwebp' 'ppc-zlib' 'ppc-zstd')
makedepends=('cmake' 'libogc2-dkp-toolchain-vars' 'patch')
options=(!strip libtool staticlibs)
source=("https://download.osgeo.org/libtiff/${_pkgname}-${pkgver}.tar.xz"
		"${_pkgname}-${pkgver}.patch")
sha256sums=('4996f0c4f93094719b1ca5c6279b20e588773ba8a247533e486416fb662ddb88'
			'eb2715f2448b05441c44b9303207a3b4432283958cdaf08377ae28cf6893ffeb')

prepare() {
	patch -Np 0 -i "${_pkgname}-${pkgver}.patch"
}

build() {
	cd "${srcdir}/${_pkgname}-${pkgver}"
	source "${DEVKITPRO}/libogc2/ppcvars.sh"
	powerpc-eabi-cmake -B build -DCMAKE_INSTALL_PREFIX="${PORTLIBS_PREFIX}" -DCMAKE_PREFIX_PATH="${PORTLIBS_PREFIX}" -Dtiff-contrib=OFF -Dtiff-docs=OFF -Dtiff-tests=OFF -Dtiff-tools=OFF
	cmake --build build
}

package() {
	cd "${srcdir}/${_pkgname}-${pkgver}"
	source "${DEVKITPRO}/libogc2/ppcvars.sh"
	DESTDIR="${pkgdir}" cmake --install build
	install -Dm 644 LICENSE.md -t "${pkgdir}${PORTLIBS_PREFIX}/licenses/${pkgname}"
}
