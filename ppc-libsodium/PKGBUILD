# Maintainer: Extrems <extrems@extremscorner.org>

_pkgname=libsodium
pkgname="ppc-${_pkgname}"
pkgver=1.0.22
pkgrel=1
pkgdesc='A modern, portable, easy to use crypto library.'
arch=('any')
url='https://libsodium.org/'
license=('ISC')
groups=('ppc-portlibs')
depends=('devkitPPC')
makedepends=('libogc2-dkp-toolchain-vars')
options=(!strip libtool staticlibs)
source=("https://download.libsodium.org/libsodium/releases/${_pkgname}-${pkgver}.tar.gz")
sha256sums=('adbdd8f16149e81ac6078a03aca6fc03b592b89ef7b5ed83841c086191be3349')

build() {
	cd "${srcdir}/${_pkgname}-${pkgver}"
	source "${DEVKITPRO}/libogc2/ppcvars.sh"
	./configure --prefix="${PORTLIBS_PREFIX}" --host=powerpc-eabi ac_cv_tls=none
	make
}

package() {
	cd "${srcdir}/${_pkgname}-${pkgver}"
	source "${DEVKITPRO}/libogc2/ppcvars.sh"
	DESTDIR="${pkgdir}" make install
	install -Dm 644 LICENSE -t "${pkgdir}${PORTLIBS_PREFIX}/licenses/${pkgname}"
}
