# Maintainer: Extrems <extrems@extremscorner.org>

_pkgname=xz
pkgname=ppc-liblzma
pkgver=5.8.3
pkgrel=1
pkgdesc='A general-purpose data compression library.'
arch=('any')
url='https://github.com/tukaani-project/xz'
license=('0BSD')
groups=('ppc-portlibs')
depends=('devkitPPC')
makedepends=('cmake' 'libogc2-dkp-toolchain-vars' 'patch')
options=(!strip libtool staticlibs)
source=("${_pkgname}-${pkgver}.tar.gz::${url}/archive/refs/tags/v${pkgver}.tar.gz"
		"${_pkgname}-${pkgver}.patch")
sha256sums=('8ec1767fa517642ecb4cf08b891ce667ba6f143551e382b07c7ef437bda335e2'
			'7c2bfee2c7f3427cc31f9c2cab922ad825cac39bafe1ab74a8f35340d882623d')

prepare() {
	patch -Np 0 -i "${_pkgname}-${pkgver}.patch"
}

build() {
	cd "${srcdir}/${_pkgname}-${pkgver}"
	source "${DEVKITPRO}/libogc2/ppcvars.sh"
	powerpc-eabi-cmake -B build -DBUILD_TESTING=OFF -DCMAKE_INSTALL_PREFIX="${PORTLIBS_PREFIX}" -DTUKLIB_CPUCORES_DEFINITIONS= -DTUKLIB_PHYSMEM_DEFINITIONS= -DXZ_DOC=OFF -DXZ_TOOL_LZMADEC=OFF -DXZ_TOOL_LZMAINFO=OFF -DXZ_TOOL_XZ=OFF -DXZ_TOOL_XZDEC=OFF
	cmake --build build
}

package() {
	cd "${srcdir}/${_pkgname}-${pkgver}"
	source "${DEVKITPRO}/libogc2/ppcvars.sh"
	DESTDIR="${pkgdir}" cmake --install build
	install -Dm 644 COPYING.0BSD -t "${pkgdir}${PORTLIBS_PREFIX}/licenses/${pkgname}"
}
