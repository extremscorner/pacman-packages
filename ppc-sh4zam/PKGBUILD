# Maintainer: Extrems <extrems@extremscorner.org>

_pkgname=sh4zam
pkgname="ppc-${_pkgname}"
pkgver=0.7.0.r54.g1a7cf03
pkgrel=1
pkgdesc='Fast linear algebra and math library for the Hitachi SuperH4 Processor.'
arch=('any')
url='https://github.com/gyrovorbis/sh4zam'
license=('MIT')
groups=('ppc-portlibs')
depends=('devkitPPC')
makedepends=('cmake' 'git' 'libogc2-dkp-toolchain-vars')
options=(!strip libtool staticlibs)
source=("git+${url}.git#commit=1a7cf0345eaae3902d1701aedefe6068eca25548")
sha256sums=('3c4c240589fb63f9c503d152313f6e5dc690c05e3dc634c195e77159f4b212cf')

pkgver() {
	cd "${srcdir}/${_pkgname}"
	git describe --tags --abbrev=7 | sed 's/^v//;s/-/.r/;s/-/./'
}

build() {
	cd "${srcdir}/${_pkgname}"
	source "${DEVKITPRO}/libogc2/ppcvars.sh"
	powerpc-eabi-cmake -B build -DCMAKE_INSTALL_PREFIX="${PORTLIBS_PREFIX}" -DSHZ_TLS_MODEL=DISABLED
	cmake --build build
}

package() {
	cd "${srcdir}/${_pkgname}"
	source "${DEVKITPRO}/libogc2/ppcvars.sh"
	DESTDIR="${pkgdir}" cmake --install build
	install -Dm 644 LICENSE -t "${pkgdir}${PORTLIBS_PREFIX}/licenses/${pkgname}"
}
