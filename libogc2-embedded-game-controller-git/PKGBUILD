# Maintainer: Extrems <extrems@extremscorner.org>

_pkgname=embedded-game-controller
pkgname="libogc2-${_pkgname}-git"
pkgver=r95.ef6cc37
pkgrel=1
pkgdesc='Game controller library for embedded devices.'
arch=('any')
url='https://github.com/extremscorner/embedded-game-controller'
license=('MIT')
groups=('wii-portlibs')
depends=('devkitPPC' 'libogc2' 'libogc2-bt-embedded')
makedepends=('cmake' 'git' 'libogc2-dkp-toolchain-vars')
provides=("libogc2-${_pkgname}")
conflicts=("libogc2-${_pkgname}")
options=(!strip libtool staticlibs)
source=("git+${url}.git")
sha256sums=('SKIP')

pkgver() {
	cd "${srcdir}/${_pkgname}"
	printf "r%s.%s" "$(git rev-list --count HEAD)" "$(git rev-parse --short=7 HEAD)"
}

build() {
	cd "${srcdir}/${_pkgname}"
	source "${DEVKITPRO}/libogc2/wiivars.sh"
	powerpc-eabi-cmake -B build
	cmake --build build
}

package() {
	cd "${srcdir}/${_pkgname}"
	source "${DEVKITPRO}/libogc2/wiivars.sh"
	DESTDIR="${pkgdir}" cmake --install build
	install -Dm 644 LICENSE -t "${pkgdir}${PORTLIBS_PREFIX}/share/licenses/${_pkgname}"
}
